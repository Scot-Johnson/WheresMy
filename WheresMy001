import SwiftUI
import MapKit

// MARK: - Models

@Observable
class MapViewModel {
    var region = MKCoordinateRegion(
        center: CLLocationCoordinate2D(latitude: 35.7796, longitude: -78.6382),
        span: MKCoordinateSpan(latitudeDelta: 0.05, longitudeDelta: 0.05)
    )
    
    var searchText = ""
    var selectedFilters: Set<String> = ["Bars & Restaurants"]
    
    let locations: [PBRLocation] = [
        PBRLocation(name: "The Flying Biscuit", coordinate: CLLocationCoordinate2D(latitude: 35.7850, longitude: -78.6550), hasProduct: true),
        PBRLocation(name: "Madre", coordinate: CLLocationCoordinate2D(latitude: 35.7820, longitude: -78.6450), hasProduct: true),
        PBRLocation(name: "St Food Hall", coordinate: CLLocationCoordinate2D(latitude: 35.7780, longitude: -78.6400), hasProduct: true),
        PBRLocation(name: "CAM Raleigh", coordinate: CLLocationCoordinate2D(latitude: 35.7750, longitude: -78.6420), hasProduct: false),
    ]
}

struct PBRLocation: Identifiable {
    let id = UUID()
    let name: String
    let coordinate: CLLocationCoordinate2D
    let hasProduct: Bool
}

