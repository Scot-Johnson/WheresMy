// MARK: - Components

struct FilterChip: View {
    let title: String
    let isSelected: Bool
    
    var body: some View {
        Text(title)
            .font(.system(size: 15, weight: .medium))
            .foregroundStyle(isSelected ? .primary : .secondary)
            .padding(.horizontal, 16)
            .padding(.vertical, 10)
            .background(isSelected ? .white : .white.opacity(0.7), in: RoundedRectangle(cornerRadius: 20))
            .shadow(color: .black.opacity(0.1), radius: 4, y: 2)
    }
}

struct LocationMarker: View {
    let hasProduct: Bool
    
    var body: some View {
        ZStack {
            Circle()
                .fill(hasProduct ? .orange : .pink)
                .frame(width: 36, height: 36)
                .shadow(color: .black.opacity(0.2), radius: 4, y: 2)
            
            Image(systemName: hasProduct ? "fork.knife" : "building.2")
                .font(.system(size: 16, weight: .medium))
                .foregroundStyle(.white)
        }
    }
}

struct PBRMarker: View {
    var body: some View {
        VStack(spacing: 0) {
            // PBR logo placeholder with text
            HStack(spacing: 4) {
                Image(systemName: "star.fill")
                    .font(.system(size: 12))
                    .foregroundStyle(.blue)
                
                Text("12oz Cans")
                    .font(.system(size: 13, weight: .semibold))
                    .foregroundStyle(.primary)
            }
            .padding(.horizontal, 12)
            .padding(.vertical, 8)
            .background(.white, in: RoundedRectangle(cornerRadius: 16))
            .shadow(color: .black.opacity(0.15), radius: 4, y: 2)
            
            // Pointer
            Triangle()
                .fill(.white)
                .frame(width: 12, height: 8)
                .offset(y: -1)
        }
    }
}

struct Triangle: Shape {
    func path(in rect: CGRect) -> Path {
        var path = Path()
        path.move(to: CGPoint(x: rect.midX, y: rect.maxY))
        path.addLine(to: CGPoint(x: rect.minX, y: rect.minY))
        path.addLine(to: CGPoint(x: rect.maxX, y: rect.minY))
        path.closeSubpath()
        return path
    }
}

